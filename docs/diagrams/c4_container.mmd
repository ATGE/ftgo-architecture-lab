System_Boundary(ftgo, "FTGO Platform") {
  Container(mobile_app, "Mobile App", "React Native / Web", "App de consumidor y courier para pedidos, tracking y entregas")
  Container(restaurant_dashboard, "Restaurant Dashboard", "Web App", "Dashboard de tickets, preparacion y disponibilidad")
  Container(backoffice_web, "Back Office Web", "Web App", "Operaciones, soporte y reportes")
  Container(api_gateway, "API Gateway", "Spring Cloud Gateway", "Entrada HTTP, routing Strangler Fig y auth")

  Container(consumer_service, "Consumer Service", "Java 17 / Spring Boot", "Perfiles, direcciones y preferencias")
  Container(restaurant_service, "Restaurant Service", "Java 17 / Spring Boot", "Restaurantes, menus, horarios y disponibilidad")
  Container(order_service, "Order Service", "Java 17 / Spring Boot", "Toma de pedidos, validacion y estado principal")
  Container(kitchen_service, "Kitchen Service", "Java 17 / Spring Boot", "Tickets de cocina y preparacion")
  Container(delivery_service, "Delivery Service", "Java 17 / Spring Boot", "Asignacion de couriers, rutas y tracking")
  Container(billing_service, "Billing Service", "Java 17 / Spring Boot", "Cobros, comisiones y payouts")
  Container(notification_service, "Notification Service", "Java 17 / Spring Boot", "Email, SMS, push y recibos")
  ContainerQueue(event_broker, "Event Broker", "Apache Kafka", "Eventos de dominio y procesos asincronos")

  ContainerDb(consumer_db, "Consumer DB", "PostgreSQL", "Datos de consumidores")
  ContainerDb(restaurant_db, "Restaurant DB", "PostgreSQL", "Restaurantes y menus")
  ContainerDb(order_db, "Order DB", "PostgreSQL", "Pedidos y aggregate de pedido")
  ContainerDb(kitchen_db, "Kitchen DB", "PostgreSQL", "Tickets y estados de preparacion")
  ContainerDb(delivery_db, "Delivery DB", "PostgreSQL", "Asignaciones y tracking")
  ContainerDb(billing_db, "Billing DB", "PostgreSQL", "Pagos y registros contables")
  ContainerDb(notification_db, "Notification DB", "PostgreSQL", "Logs de notificaciones y retries")
}

